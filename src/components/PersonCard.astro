---
interface Props {
  name: string;
  role: string;
}
const { name, role } = Astro.props;

// Initials, ignoring honorifics (tokens ending in ".", e.g. "Prof.", "Dr.").
const initials =
  name
    .split(/\s+/)
    .filter((w) => !w.endsWith("."))
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase() ?? "")
    .join("") || name.slice(0, 2).toUpperCase();
---

<article class="border-line flex items-center gap-4 rounded-2xl border bg-white p-5">
  <div
    class="bg-navy/[0.06] ring-navy/10 flex h-16 w-16 shrink-0 items-center justify-center rounded-full ring-1"
    aria-hidden="true"
  >
    <span class="font-display text-navy text-lg font-bold">{initials}</span>
  </div>
  <div>
    <p class="text-navy-500 text-xs font-semibold tracking-wider uppercase">{role}</p>
    <h3 class="text-navy mt-0.5 text-lg font-semibold">{name}</h3>
  </div>
</article>
