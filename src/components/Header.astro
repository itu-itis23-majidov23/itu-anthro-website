---
import { localizedPath, getDictionary, type Lang, type RouteKey } from "../i18n/utils";
import Logo from "./Logo.astro";
import Nav from "./Nav.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import LanguagePicker from "./LanguagePicker.astro";

interface Props {
  lang: Lang;
  currentKey: RouteKey | null;
}
const { lang, currentKey } = Astro.props;
const dict = getDictionary(lang);
const homeHref = localizedPath("home", lang);
const joinHref = localizedPath("join", lang);
---

<header
  id="site-header"
  data-scrolled="false"
  class="data-[scrolled=true]:border-line sticky top-0 z-50 border-b border-transparent bg-white/85 backdrop-blur-md transition-[box-shadow,border-color] data-[scrolled=true]:shadow-[0_4px_24px_-12px_rgba(0,40,85,0.25)]"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <a
      href={homeHref}
      class="text-navy rounded-md transition-opacity hover:opacity-85"
      aria-label={dict.brand.name}
    >
      <Logo class="h-12" />
    </a>

    <nav class="hidden lg:block" aria-label={dict.ui.menuLabel}>
      <Nav lang={lang} currentKey={currentKey} />
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <LanguagePicker lang={lang} routeKey={currentKey ?? "home"} class="text-navy" />
      <Button href={joinHref} variant="primary" arrow>{dict.ui.joinUs}</Button>
    </div>

    <div class="lg:hidden">
      <button
        type="button"
        id="mobile-menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={dict.ui.openMenu}
        class="text-navy hover:bg-navy/5 inline-flex h-10 w-10 items-center justify-center rounded-lg transition"
      >
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>
</header>

<script>
  // One persistent scroll listener that re-targets the (swapped) header after
  // each view-transition navigation.
  const updateHeader = () => {
    const header = document.getElementById("site-header");
    if (header) header.dataset.scrolled = window.scrollY > 8 ? "true" : "false";
  };
  window.addEventListener("scroll", updateHeader, { passive: true });
  document.addEventListener("astro:page-load", updateHeader);
</script>
