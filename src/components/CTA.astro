---
import Container from "./Container.astro";
import Button from "./Button.astro";

interface Props {
  title: string;
  body?: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  primaryExternal?: boolean;
}
const {
  title,
  body,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  primaryExternal = false,
} = Astro.props;
---

<section class="bg-navy-grad relative overflow-hidden text-white">
  <div class="tech-dots absolute inset-0 opacity-50" aria-hidden="true"></div>
  <Container class="relative py-14 sm:py-16">
    <div class="flex flex-col gap-7 md:flex-row md:items-center md:justify-between md:gap-10">
      <div class="max-w-2xl">
        <h2 class="text-3xl text-white sm:text-4xl">{title}</h2>
        {body && <p class="mt-3 text-lg leading-relaxed text-white/75">{body}</p>}
      </div>
      <div class="flex shrink-0 flex-wrap gap-3">
        <Button href={primaryHref} variant="white" size="lg" arrow external={primaryExternal}>
          {primaryLabel}
        </Button>
        {
          secondaryHref && secondaryLabel && (
            <Button href={secondaryHref} variant="ghost" size="lg">
              {secondaryLabel}
            </Button>
          )
        }
      </div>
    </div>
  </Container>
</section>
