---
interface Props {
  value: string;
  label: string;
  invert?: boolean;
}
const { value, label, invert = false } = Astro.props;
---

<div
  class:list={[
    "rounded-xl border px-4 py-4 text-center sm:text-left",
    invert ? "border-white/15 bg-white/[0.06]" : "border-line bg-white",
  ]}
>
  <div class={`font-display text-2xl font-bold sm:text-3xl ${invert ? "text-white" : "text-navy"}`}>
    {value}
  </div>
  <div class={`mt-1 text-xs leading-snug ${invert ? "text-white/65" : "text-muted"}`}>
    {label}
  </div>
</div>
