---
import { NAV_ORDER, localizedPath, getDictionary, type Lang, type RouteKey } from "../i18n/utils";
import Icon from "./Icon.astro";
import Button from "./Button.astro";
import LanguagePicker from "./LanguagePicker.astro";

// The toggle button lives in the Header; this overlay is rendered at body level
// (NOT inside the header) because the header's backdrop-blur would otherwise
// become the containing block for this position:fixed panel and clamp it.
interface Props {
  lang: Lang;
  currentKey: RouteKey | null;
}
const { lang, currentKey } = Astro.props;
const dict = getDictionary(lang);
const joinHref = localizedPath("join", lang);
const navKeys: RouteKey[] = [...NAV_ORDER, "support"];
---

<div
  id="mobile-menu"
  hidden
  class="fixed inset-0 z-[100] lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={dict.ui.menuLabel}
>
  <div id="mobile-menu-backdrop" class="bg-navy/70 absolute inset-0 backdrop-blur-sm"></div>
  <nav class="absolute inset-y-0 right-0 flex w-[88%] max-w-sm flex-col bg-white shadow-2xl">
    <div class="border-line flex items-center justify-between border-b px-5 py-4">
      <span class="font-display text-navy text-sm font-semibold">{dict.ui.menuLabel}</span>
      <button
        type="button"
        id="mobile-menu-close"
        aria-label={dict.ui.closeMenu}
        class="text-navy hover:bg-navy/5 inline-flex h-10 w-10 items-center justify-center rounded-lg transition"
      >
        <Icon name="close" size={22} />
      </button>
    </div>

    <ul class="flex-1 overflow-y-auto px-3 py-4">
      {
        navKeys.map((key) => {
          const active = key === currentKey;
          return (
            <li>
              <a
                href={localizedPath(key, lang)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "flex items-center justify-between rounded-xl px-4 py-3 text-base font-semibold transition-colors",
                  active ? "bg-navy text-white" : "text-ink hover:bg-navy/[0.06] hover:text-navy",
                ]}
              >
                {dict.nav[key]}
                {active && <Icon name="arrow-right" size={16} />}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="border-line flex items-center justify-between gap-3 border-t bg-white px-5 py-5">
      <Button href={joinHref} variant="primary" arrow>{dict.ui.joinUs}</Button>
      <LanguagePicker lang={lang} routeKey={currentKey ?? "home"} class="text-navy" />
    </div>
  </nav>
</div>

<script>
  function setupMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const closeBtn = document.getElementById("mobile-menu-close");
    const backdrop = document.getElementById("mobile-menu-backdrop");
    if (!toggle || !menu) return;

    const open = () => {
      menu.hidden = false;
      toggle.setAttribute("aria-expanded", "true");
      document.documentElement.style.overflow = "hidden";
      menu.querySelector<HTMLElement>("a, button")?.focus();
    };
    const close = () => {
      menu.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
      document.documentElement.style.overflow = "";
    };

    toggle.addEventListener("click", open);
    closeBtn?.addEventListener("click", close);
    backdrop?.addEventListener("click", close);
    // Close when a link is tapped so the menu doesn't linger during navigation.
    menu.querySelectorAll("a[href]").forEach((a) => a.addEventListener("click", close));
  }

  document.addEventListener("astro:page-load", setupMobileMenu);

  // Esc closes the menu; also release the scroll lock after every navigation
  // (the <html> element persists across view-transition swaps).
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    const menu = document.getElementById("mobile-menu");
    if (menu && !menu.hidden) {
      menu.hidden = true;
      document.getElementById("mobile-menu-toggle")?.setAttribute("aria-expanded", "false");
      document.documentElement.style.overflow = "";
    }
  });
  document.addEventListener("astro:after-swap", () => {
    document.documentElement.style.overflow = "";
  });
</script>
