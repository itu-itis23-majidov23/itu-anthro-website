---
import { NAV_ORDER, localizedPath, getDictionary, type Lang, type RouteKey } from "../i18n/utils";
import Icon from "./Icon.astro";
import Button from "./Button.astro";
import LanguagePicker from "./LanguagePicker.astro";

interface Props {
  lang: Lang;
  currentKey: RouteKey | null;
}
const { lang, currentKey } = Astro.props;
const dict = getDictionary(lang);
const joinHref = localizedPath("join", lang);
const supportHref = localizedPath("support", lang);
---

<div class="lg:hidden">
  <button
    type="button"
    id="mobile-menu-toggle"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label={dict.ui.openMenu}
    class="text-navy hover:bg-navy/5 inline-flex h-10 w-10 items-center justify-center rounded-lg transition"
  >
    <Icon name="menu" size={24} />
  </button>
</div>

<div
  id="mobile-menu"
  hidden
  class="fixed inset-0 z-[60] lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={dict.ui.menuLabel}
>
  <div id="mobile-menu-backdrop" class="bg-navy/40 absolute inset-0 backdrop-blur-sm"></div>
  <nav class="absolute top-0 right-0 flex h-full w-[82%] max-w-sm flex-col bg-white shadow-2xl">
    <div class="border-line flex items-center justify-between border-b px-5 py-4">
      <span class="font-display text-navy text-sm font-semibold">{dict.ui.menuLabel}</span>
      <button
        type="button"
        id="mobile-menu-close"
        aria-label={dict.ui.closeMenu}
        class="text-navy hover:bg-navy/5 inline-flex h-10 w-10 items-center justify-center rounded-lg transition"
      >
        <Icon name="close" size={22} />
      </button>
    </div>

    <ul class="flex flex-col gap-1 px-3 py-5">
      {
        NAV_ORDER.map((key) => {
          const active = key === currentKey;
          return (
            <li>
              <a
                href={localizedPath(key, lang)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "block rounded-lg px-4 py-3 text-base font-medium transition-colors",
                  active ? "bg-navy/5 text-navy" : "text-ink/80 hover:bg-navy/5 hover:text-navy",
                ]}
              >
                {dict.nav[key]}
              </a>
            </li>
          );
        })
      }
      <li>
        <a
          href={supportHref}
          aria-current={currentKey === "support" ? "page" : undefined}
          class="text-ink/80 hover:bg-navy/5 hover:text-navy block rounded-lg px-4 py-3 text-base font-medium transition-colors"
        >
          {dict.nav.support}
        </a>
      </li>
    </ul>

    <div class="border-line mt-auto flex items-center justify-between gap-3 border-t px-5 py-5">
      <Button href={joinHref} variant="primary" arrow>{dict.ui.joinUs}</Button>
      <LanguagePicker lang={lang} routeKey={currentKey ?? "home"} class="text-navy" />
    </div>
  </nav>
</div>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const closeBtn = document.getElementById("mobile-menu-close");
  const backdrop = document.getElementById("mobile-menu-backdrop");

  function openMenu() {
    if (!menu || !toggle) return;
    menu.hidden = false;
    toggle.setAttribute("aria-expanded", "true");
    document.documentElement.style.overflow = "hidden";
    const firstLink = menu.querySelector<HTMLAnchorElement>("a, button");
    firstLink?.focus();
  }

  function closeMenu() {
    if (!menu || !toggle) return;
    menu.hidden = true;
    toggle.setAttribute("aria-expanded", "false");
    document.documentElement.style.overflow = "";
    toggle.focus();
  }

  toggle?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menu && !menu.hidden) closeMenu();
  });
</script>
