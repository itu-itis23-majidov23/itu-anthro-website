---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  name: string;
  tagline: string;
  description: string;
  tags: string[];
  statusLabel: string;
}
const { iconName, name, tagline, description, tags, statusLabel } = Astro.props;
---

<article
  class="group border-line hover:border-sky flex h-full flex-col rounded-2xl border bg-white p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_18px_40px_-24px_rgba(0,40,85,0.45)]"
>
  <div class="flex items-start justify-between gap-4">
    <div
      class="bg-navy/[0.06] text-navy group-hover:bg-navy inline-flex h-12 w-12 items-center justify-center rounded-xl transition-colors group-hover:text-white"
    >
      <Icon name={iconName} size={24} />
    </div>
    <span
      class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
      {statusLabel}
    </span>
  </div>

  <h3 class="text-navy mt-5 text-lg font-semibold">{name}</h3>
  <p class="text-navy-500 mt-1 text-sm font-medium">{tagline}</p>
  <p class="text-muted mt-3 text-sm leading-relaxed">{description}</p>

  <div class="border-line mt-5 flex flex-wrap gap-2 border-t pt-4">
    {
      tags.map((tag) => (
        <span class="bg-sky-soft text-navy-700 rounded-full px-2.5 py-1 text-xs font-medium">
          {tag}
        </span>
      ))
    }
  </div>
</article>
