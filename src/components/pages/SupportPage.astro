---
import { type Lang, getDictionary } from "../../i18n/utils";
import { site } from "../../data/site";
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../Section.astro";
import SectionHeading from "../SectionHeading.astro";
import Icon from "../Icon.astro";
import Reveal from "../Reveal.astro";
import CTA from "../CTA.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = getDictionary(lang);
const s = dict.support;
const wayIcons = ["trophy", "business", "gear"];
const mailto = `mailto:${site.email}`;
---

<PageLayout
  lang={lang}
  routeKey="support"
  metaTitle={s.meta.title}
  metaDescription={s.meta.description}
  eyebrow={s.eyebrow}
  title={s.title}
  lead={s.lead}
>
  {/* Why support */}
  <Section size="narrow">
    <SectionHeading title={s.whyTitle} description={s.whyBody} />
  </Section>

  {/* Ways to support */}
  <Section soft>
    <SectionHeading title={s.waysTitle} />
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        s.ways.map((way, i) => (
          <Reveal delay={i * 70} class="h-full">
            <article class="border-line h-full rounded-2xl border bg-white p-6">
              <div class="bg-navy/[0.06] text-navy inline-flex h-12 w-12 items-center justify-center rounded-xl">
                <Icon name={wayIcons[i] ?? "business"} size={24} />
              </div>
              <h3 class="text-navy mt-5 text-lg font-semibold">{way.title}</h3>
              <p class="text-muted mt-2 text-sm leading-relaxed">{way.body}</p>
            </article>
          </Reveal>
        ))
      }
    </div>
  </Section>

  {/* Sponsors — honest empty state */}
  <Section>
    <SectionHeading title={s.sponsorsTitle} align="center" class="mx-auto" />
    <div
      class="border-line bg-bg-soft mt-8 flex flex-col items-center justify-center rounded-2xl border border-dashed px-6 py-14 text-center"
    >
      <div
        class="bg-navy/[0.06] text-navy/50 inline-flex h-12 w-12 items-center justify-center rounded-full"
      >
        <Icon name="trophy" size={24} />
      </div>
      <p class="text-muted mt-4 max-w-md">{s.sponsorsNote}</p>
    </div>
  </Section>

  <CTA title={s.ctaTitle} body={s.ctaBody} primaryHref={mailto} primaryLabel={dict.ui.contactUs} />
</PageLayout>
