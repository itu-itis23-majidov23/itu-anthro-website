---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  body: string;
  tags?: string[];
}
const { iconName, title, body, tags } = Astro.props;
---

<article
  class="group border-line hover:border-sky h-full rounded-2xl border bg-white p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_18px_40px_-24px_rgba(0,40,85,0.45)]"
>
  <div
    class="bg-navy/[0.06] text-navy group-hover:bg-navy inline-flex h-12 w-12 items-center justify-center rounded-xl transition-colors group-hover:text-white"
  >
    <Icon name={iconName} size={24} />
  </div>
  <h3 class="text-navy mt-5 text-lg font-semibold">{title}</h3>
  <p class="text-muted mt-2 text-sm leading-relaxed">{body}</p>
  {
    tags && tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="bg-sky-soft text-navy-700 rounded-full px-2.5 py-1 text-xs font-medium">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</article>
