---
import Icon from "./Icon.astro";

interface Props {
  href: string;
  variant?: "primary" | "outline" | "white" | "ghost";
  size?: "md" | "lg";
  arrow?: boolean;
  external?: boolean;
  class?: string;
}
const {
  href,
  variant = "primary",
  size = "md",
  arrow = false,
  external = false,
  class: className = "",
} = Astro.props;

const base =
  "group inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2";

const sizes: Record<string, string> = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-7 py-3.5 text-base",
};

const variants: Record<string, string> = {
  primary: "bg-navy text-white shadow-sm hover:bg-navy-700 hover:shadow-md",
  outline: "border border-navy/20 text-navy hover:border-navy/40 hover:bg-navy/[0.04]",
  white: "bg-white text-navy shadow-sm hover:bg-sky-soft",
  ghost: "text-white/90 ring-1 ring-white/30 hover:bg-white/10 hover:ring-white/50",
};

const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<a
  href={href}
  rel={rel}
  target={target}
  class={`${base} ${sizes[size]} ${variants[variant]} ${className}`}
>
  <slot />
  {
    arrow && (
      <Icon name="arrow-right" size={17} class="transition-transform group-hover:translate-x-0.5" />
    )
  }
</a>
