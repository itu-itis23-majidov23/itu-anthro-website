---
import { type Lang, type RouteKey } from "../i18n/utils";
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/Container.astro";

interface Props {
  lang: Lang;
  routeKey: RouteKey;
  metaTitle: string;
  metaDescription: string;
  eyebrow: string;
  title: string;
  lead?: string;
}
const { lang, routeKey, metaTitle, metaDescription, eyebrow, title, lead } = Astro.props;
---

<BaseLayout lang={lang} routeKey={routeKey} title={metaTitle} description={metaDescription}>
  <section class="bg-navy-grad relative overflow-hidden text-white">
    <div class="tech-dots absolute inset-0 opacity-60"></div>
    <Container class="relative py-16 sm:py-20 lg:py-24">
      <p class="text-accent text-xs font-semibold tracking-[0.18em] uppercase">
        {eyebrow}
      </p>
      <h1 class="mt-3 max-w-3xl text-4xl text-white sm:text-5xl">{title}</h1>
      {lead && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/75">{lead}</p>}
    </Container>
  </section>

  <slot />
</BaseLayout>
