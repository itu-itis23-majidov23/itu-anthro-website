---
import "@fontsource-variable/inter";
import "@fontsource-variable/sora";
import "../styles/global.css";

import { type Lang, type RouteKey, getDictionary, htmlLang, withBase } from "../i18n/utils";
import { site, assets } from "../data/site";
import Seo from "../components/Seo.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  lang: Lang;
  routeKey: RouteKey;
  title: string;
  description: string;
  ogImage?: string;
}
const { lang, routeKey, title, description, ogImage } = Astro.props;
const dict = getDictionary(lang);

const fullTitle = routeKey === "home" ? `${site.name} · ${title}` : `${title} · ${site.name}`;
const faviconHref = withBase(assets.favicon);
const faviconPngHref = withBase(assets.faviconPng);
const appleTouchHref = withBase(assets.appleTouchIcon);
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href={faviconPngHref} />
    <link rel="apple-touch-icon" href={appleTouchHref} />
    <meta name="theme-color" content="#002855" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      lang={lang}
      routeKey={routeKey}
      title={fullTitle}
      description={description}
      ogImage={ogImage}
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white antialiased">
    <a
      href="#main"
      class="bg-navy absolute top-3 left-4 z-[100] -translate-y-20 rounded-md px-4 py-2 text-sm font-medium text-white transition-transform focus:translate-y-0"
    >
      {dict.ui.skipToContent}
    </a>

    <Header lang={lang} currentKey={routeKey} />

    <main id="main">
      <slot />
    </main>

    <Footer lang={lang} />

    <script>
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
